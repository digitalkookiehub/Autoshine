# =============================================
# Autoshine Studio — Environment Variables
# Copy to .env and fill in your values
# =============================================

# Database
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_NAME=autoshine
DATABASE_URL=postgresql://postgres:your-secure-password@localhost:5432/autoshine

# JWT Auth
SECRET_KEY=your-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Settings
OTP_EXPIRE_MINUTES=10
OTP_MAX_REQUESTS_PER_HOUR=3

# Twilio (SMS OTP) — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Expo Push — https://expo.dev/accounts/[username]/settings/access-tokens
EXPO_ACCESS_TOKEN=your-expo-access-token

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxxxxxx.apps.googleusercontent.com
